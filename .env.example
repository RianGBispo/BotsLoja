# ===== Discord =====
DISCORD_TOKEN=seu_token_do_bot_aqui
DISCORD_CLIENT_ID=id_da_aplicacao
GUILD_ID=id_do_seu_servidor

# Cargo da equipe (quem pode aprovar/recusar pagamentos)
STAFF_ROLE_ID=id_do_cargo_equipe

# Canais
TICKET_CATEGORY_ID=id_da_categoria_onde_os_tickets_sao_criados
# Canal onde fica o painel "Abrir ticket" (postado com /painel) — citado no card de boas-vindas
TICKET_PANEL_CHANNEL_ID=id_do_canal_do_painel
CATALOG_CHANNEL_ID=id_do_canal_catalogo
SALES_CHANNEL_ID=id_do_canal_vendas
# Canal onde as transcrições dos tickets fechados são postadas (deixe vazio pra desativar)
TRANSCRIPT_CHANNEL_ID=id_do_canal_transcricoes

# ===== Boas-vindas (mensagem quando alguém entra no servidor) =====
# Canal onde o card de boas-vindas é postado (deixe vazio pra desativar)
WELCOME_CHANNEL_ID=id_do_canal_boas_vindas
# Título do card (opcional). Se vazio: "🩷 Seja bem-vindo(a) ao <BRAND_NAME>!"
WELCOME_TITLE=
# Banner grande exibido no card de boas-vindas. Cole a URL de uma imagem.
WELCOME_IMAGE_URL=
# (A imagem pequena no canto é o avatar do usuário que entrou — vem do Discord.)

# ===== Supabase =====
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=service_role_key_do_supabase

# ===== Pix (Copia e Cola / BR Code) =====
PIX_KEY=sua_chave_pix
PIX_MERCHANT_NAME=MoonLight
PIX_MERCHANT_CITY=SAO PAULO

# A entrega é manual: ao aprovar, a equipe anexa o arquivo no próprio ticket.

# ===== Identidade visual dos embeds =====
# Cor de destaque dos embeds (hex sem #)
BRAND_COLOR=D4AF37
# Nome da marca (aparece no rodapé e em títulos)
BRAND_NAME=MoonLight
# Faixa/banner exibida embaixo das mensagens. Cole a URL de uma imagem (ex.: link do Discord
# ou do Supabase Storage). Largura recomendada ~960px. Deixe vazio pra não mostrar faixa.
BRAND_BANNER_URL=
# Ícone do rodapé (opcional, ex.: logo redonda da loja). Deixe vazio pra não mostrar ícone.
BRAND_LOGO_URL=
# Texto do rodapé. Se vazio, usa "© <ano> <BRAND_NAME> • Todos os direitos reservados."
BRAND_FOOTER=
